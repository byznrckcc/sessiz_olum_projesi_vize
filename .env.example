# --- Uygulama Ayarları ---
PORT=3000
NODE_ENV=development

# --- Redis Yapılandırması (IPS Mekanizması İçin) ---
# Yerel kullanım için varsayılan: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# --- Güvenlik (JWT) Ayarları ---
# Buraya gerçek secret yazılmaz, sadece ne olduğu belirtilir
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=1h

# --- IPS / Ban Limitleri ---
IPS_ATTEMPT_LIMIT=3
BAN_DURATION_SECONDS=86400